#!/bin/bash
set -euo pipefail

# Auto — daemon process manager (Go). This facade builds and code-signs Auto.app,
# runs the quality gate, and installs the watch daemon as its own LaunchAgent. The
# signed bundle is what makes auto the stable "responsible process" for every
# service it spawns, so a single macOS Local Network grant covers them all.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SRC_DIR="$SCRIPT_DIR/src"
OUTPUT_DIR="$SCRIPT_DIR/output"
BIN_DIR="$OUTPUT_DIR/bin"
TEST_DIR="$OUTPUT_DIR/testing"
APP_BUNDLE="$OUTPUT_DIR/Auto.app"
APP_EXE="$APP_BUNDLE/Contents/MacOS/auto"
BUNDLE_ID="com.darrenoakey.auto"

mkdir -p "$BIN_DIR" "$TEST_DIR"

usage() {
    echo "Usage: $0 <command> [args]"
    echo ""
    echo "Build/admin commands:"
    echo "  build              Build binaries and the signed Auto.app bundle"
    echo "  test [pkg] [args]  Run tests for a package"
    echo "  lint               Run gofmt, go vet, and golangci-lint"
    echo "  check              Full quality gate (lint + all tests)"
    echo "  install            Build, sign, and (re)load the Auto LaunchAgent"
    echo "  rebuild            Alias for install"
    echo "  logs               Tail the live auto daemon log"
    echo ""
    echo "Anything else is passed straight to the signed binary, e.g.:"
    echo "  ps  start <name>  stop <name>  restart <name>  add ...  stop-all  ..."
    exit 1
}

# signing_identity finds a STABLE code-signing identity (Apple Development /
# Developer ID for Darren Oakey). A stable identity is what makes the macOS Local
# Network grant survive rebuilds: TCC keys on the Designated Requirement (Team ID
# + bundle id), constant across builds and cert renewals. Falls back to ad-hoc
# ("-") with a warning — ad-hoc changes identity every build so the grant would
# NOT persist.
signing_identity() {
    local id
    id="$( (security find-identity -v -p codesigning 2>/dev/null \
            | grep -E "Apple Development: Darren Oakey|Developer ID Application: " \
            | head -1 | awk '{print $2}') || true )"
    if [ -n "$id" ]; then
        echo "$id"
    else
        echo "-"
    fi
}

cmd_build() {
    echo "==> Building..."
    cd "$SRC_DIR"
    for dir in cmd/*/; do
        name=$(basename "$dir")
        go build -o "$BIN_DIR/$name" "./$dir"
        echo "    Built $name -> output/bin/$name"
    done
    cmd_bundle
    echo "==> Build complete."
}

# cmd_bundle assembles output/Auto.app around the built binary and code-signs it
# with a stable identity + fixed bundle id, so macOS attributes Local Network
# access to the bundle (not a launcher) and the user's one-time grant persists.
cmd_bundle() {
    local id; id="$(signing_identity)"
    echo "==> Bundling Auto.app (sign id: $id)"
    rm -rf "$APP_BUNDLE"
    mkdir -p "$APP_BUNDLE/Contents/MacOS" "$APP_BUNDLE/Contents/Resources"
    cp "$BIN_DIR/auto" "$APP_EXE"
    cp "$SRC_DIR/cmd/auto/bundle/Info.plist" "$APP_BUNDLE/Contents/Info.plist"
    if [ "$id" = "-" ]; then
        echo "    WARNING: no stable signing identity found; ad-hoc signing — the"
        echo "             Local Network grant will NOT persist across rebuilds."
    fi
    codesign --force --options runtime --identifier "$BUNDLE_ID" \
        --sign "$id" "$APP_BUNDLE" 2>&1 | sed 's/^/    /'
    echo "    Bundled -> output/Auto.app"
    codesign -dv "$APP_BUNDLE" 2>&1 \
        | grep -E "Identifier|TeamIdentifier|Authority=Apple Development|Authority=Developer ID" \
        | sed 's/^/    /' || true
}

cmd_test() {
    local pkg="${1:-./...}"
    shift 2>/dev/null || true
    cd "$SRC_DIR"
    echo "==> Testing $pkg"
    go test "$pkg" -count=1 "$@" 2>&1 | tee "$TEST_DIR/test.log"
}

cmd_lint() {
    cd "$SRC_DIR"
    local failed=0
    echo "==> Checking formatting..."
    if [ -n "$(gofmt -l .)" ]; then
        echo "FAIL: gofmt found unformatted files:"; gofmt -l .; failed=1
    else
        echo "    gofmt: clean"
    fi
    echo "==> Running go vet..."
    if ! go vet ./...; then failed=1; else echo "    go vet: clean"; fi
    echo "==> Running golangci-lint..."
    if command -v golangci-lint &>/dev/null; then
        if ! golangci-lint run ./...; then failed=1; else echo "    golangci-lint: clean"; fi
    else
        echo "    golangci-lint: not installed, skipping"
    fi
    if [ "$failed" -ne 0 ]; then echo "==> Lint FAILED"; return 1; fi
    echo "==> Lint passed."
}

cmd_check() {
    echo "==> Running full quality gate..."
    cmd_lint
    echo ""
    cd "$SRC_DIR"
    echo "==> Running all tests..."
    go test ./... -count=1 2>&1 | tee "$TEST_DIR/check.log"
    echo "==> Quality gate PASSED. Safe to commit."
}

cmd_install() {
    cmd_build
    echo "==> Installing signed daemon..."
    "$APP_EXE" -q install
}

LA_LOG="$SCRIPT_DIR/output/logs/auto/auto.log"

cmd_logs() {
    if [ ! -f "$LA_LOG" ]; then
        echo "No auto log yet at $LA_LOG" >&2; exit 1
    fi
    echo "==> Tailing $LA_LOG (Ctrl-C to stop)"
    tail -n 50 -f "$LA_LOG"
}

# run_binary passes runtime subcommands to the signed binary, building it first
# if it is missing.
run_binary() {
    if [ ! -x "$APP_EXE" ]; then
        echo "==> Auto.app not built yet; building..." >&2
        cmd_build >&2
    fi
    exec "$APP_EXE" "$@"
}

case "${1:-}" in
    build)   shift; cmd_build "$@" ;;
    bundle)  shift; cmd_bundle "$@" ;;
    test)    shift; cmd_test "$@" ;;
    lint)    shift; cmd_lint "$@" ;;
    check)   shift; cmd_check "$@" ;;
    install) shift; cmd_install "$@" ;;
    rebuild) shift; cmd_install "$@" ;;
    logs)    shift; cmd_logs "$@" ;;
    "")      usage ;;
    *)       run_binary "$@" ;;
esac
